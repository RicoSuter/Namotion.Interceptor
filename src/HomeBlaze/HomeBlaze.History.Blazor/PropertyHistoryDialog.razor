@using HomeBlaze.History
@using HomeBlaze.History.Abstractions
@using Namotion.Interceptor.Registry.Abstractions
@using HomeBlaze.Services
@inject ITimeZoneDisplay TimeZone
@implements IDisposable

<MudDialog Style="height:80vh; max-height:90vh;">
    <DialogContent>
        <div style="display:flex; flex-direction:column; height:100%;">
        <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center; flex:0 0 auto;">
            <MudSelect T="int" Value="_rangeIndex" ValueChanged="OnRangeChanged" Label="Range" Dense="true" Style="min-width:160px;"
                       HelperText="@_rangeHint">
                @for (var index = 0; index < Presets.Length; index++)
                {
                    var captured = index;
                    <MudSelectItem T="int" Value="captured">@Presets[captured].Label</MudSelectItem>
                }
            </MudSelect>

            @if (_useCustom)
            {
                <MudDatePicker @bind-Date="_customFrom" @bind-Date:after="LoadAsync" Label="From" />
                <MudDatePicker @bind-Date="_customTo" @bind-Date:after="LoadAsync" Label="To" />
            }

            <MudSelect T="string" Value="_aggregation" ValueChanged="OnAggregationChanged" Label="Aggregation" Dense="true" Style="min-width:200px;"
                       Disabled="IsRawPeriodSelected" HelperText="@(IsRawPeriodSelected ? "Not applicable to raw samples." : _aggregationHint)">
                @foreach (var aggregation in _aggregations)
                {
                    <MudSelectItem T="string" Value="aggregation">@Label(aggregation)</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int" Value="_periodIndex" ValueChanged="OnPeriodChanged" Label="Period" Dense="true" Style="min-width:120px;"
                       HelperText="@_periodHint">
                @for (var index = 0; index < PropertyHistoryChartModel.Periods.Count; index++)
                {
                    var captured = index;
                    <MudSelectItem T="int" Value="captured">@PropertyHistoryChartModel.Periods[captured].Label</MudSelectItem>
                }
            </MudSelect>
        </div>

        <div style="flex:1 1 auto; min-height:0; margin-top:16px;">
            @if (_loading)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_error is not null)
            {
                <MudAlert Severity="Severity.Warning">@_error</MudAlert>
            }
            else if (_chartSeries is { Count: > 0 })
            {
                <MudChart ChartType="ChartType.Timeseries"
                          T="double"
                          ChartSeries="_chartSeries"
                          ChartOptions="_chartOptions"
                          Width="100%" Height="100%" />
            }
            else if (_tableRows is { Count: > 0 })
            {
                <MudSimpleTable Dense="true" Style="max-height:100%; overflow:auto;">
                    <thead><tr><th>Time</th><th>Value</th></tr></thead>
                    <tbody>
                    @foreach (var row in _tableRows)
                    {
                        <tr><td>@TimeZone.ToZoned(row.Time).ToString("g")</td><td>@row.Value</td></tr>
                    }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No data in this range.</MudText>
            }
        </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public string PropertyPath { get; set; } = string.Empty;
    [Parameter] public string DisplayName { get; set; } = string.Empty;
    [Parameter] public ISubjectRegistry Registry { get; set; } = default!;
    [Parameter] public Type PropertyType { get; set; } = typeof(double);
    [Parameter] public bool IsCumulative { get; set; }

    private static readonly (string Label, TimeSpan? Range)[] Presets =
    {
        ("Last hour", TimeSpan.FromHours(1)),
        ("Last 6 hours", TimeSpan.FromHours(6)),
        ("Last 24 hours", TimeSpan.FromHours(24)),
        ("Last 7 days", TimeSpan.FromDays(7)),
        ("Last 30 days", TimeSpan.FromDays(30)),
        ("Custom", null),
    };

    private int _rangeIndex; // default: last hour (index 0), so a fresh system shows recent data
    private bool _useCustom;
    private DateTime? _customFrom;
    private DateTime? _customTo;

    private IReadOnlyList<string> _aggregations = Array.Empty<string>();
    private string _aggregation = HistoryAggregations.Last;

    private int _periodIndex; // default: Auto (first entry)

    // Short helper lines under each select, refreshed in LoadAsync so the controls row stays balanced.
    private string? _rangeHint;
    private string? _aggregationHint;
    private string? _periodHint;

    // A raw (None) period has no bucket and is not Auto; aggregation does not apply to raw samples.
    private bool IsRawPeriodSelected =>
        !PropertyHistoryChartModel.Periods[_periodIndex].IsAuto
        && PropertyHistoryChartModel.Periods[_periodIndex].Bucket is null;

    private bool _loading;
    private string? _error;
    private List<ChartSeries<double>>? _chartSeries;
    private List<(DateTimeOffset Time, string Value)>? _tableRows;
    private CancellationTokenSource? _loadCts;

    // Single-color palette so the gap-split runs of one logical series share one color
    // (visual continuity with breaks). TimeLabelFormat / TimeLabelSpacing are updated per range in LoadAsync.
    private readonly TimeSeriesChartOptions _chartOptions = new()
    {
        ChartPalette = new[] { "#2979FF" },
        LineDisplayType = LineDisplayType.Line,
        // Single-property chart: the legend is redundant and was getting clipped, so hide it.
        ShowLegend = false,
        TimeLabelFormat = "HH:mm",
        TimeLabelSpacing = TimeSpan.FromHours(3)
    };

    protected override async Task OnInitializedAsync()
    {
        TimeZone.Changed += OnTimeZoneChanged;
        var column = HistoryColumns.GetValueColumnFor(PropertyType);
        var union = new HashSet<string>(StringComparer.Ordinal);
        foreach (var store in Registry.KnownSubjects.Keys.OfType<IHistoryStore>())
        {
            union.UnionWith(store.SupportedAggregations);
        }

        _aggregations = PropertyHistoryChartModel.GateAggregations(column, IsCumulative, union);
        _aggregation = _aggregations.Count > 0 ? _aggregations[0] : HistoryAggregations.Last;
        await LoadAsync();
    }

    private async Task OnRangeChanged(int index)
    {
        _rangeIndex = index;
        _useCustom = Presets[index].Range is null;
        await LoadAsync();
    }

    private async Task OnAggregationChanged(string aggregation)
    {
        _aggregation = aggregation;
        await LoadAsync();
    }

    private async Task OnPeriodChanged(int index)
    {
        _periodIndex = index;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        // Cancel any in-flight load so a slower earlier query cannot overwrite this newer selection.
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        var cancellationToken = _loadCts.Token;

        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            // Custom date picks are wall-clock dates; interpret them in the selected display time zone (not
            // UTC) so the queried window matches what the user picked. Presets anchor to "now"; the chart and
            // labels convert to the display time zone for rendering.
            var to = _useCustom
                ? (_customTo is { } customTo ? TimeZone.ToUtc(customTo) : DateTimeOffset.UtcNow)
                : DateTimeOffset.UtcNow;
            var from = _useCustom
                ? (_customFrom is { } customFrom ? TimeZone.ToUtc(customFrom) : to.AddHours(-1))
                : to - Presets[_rangeIndex].Range!.Value;

            if (to <= from)
            {
                _error = "The 'to' time must be after 'from'.";
                _chartSeries = null;
                _tableRows = null;
                return;
            }

            var range = to - from;

            // When the range is far wider than the data that actually exists, an Auto bucket of range/200 can be
            // larger than any store's coverage, so no bucket fits and the chart is empty. Clamp Auto to the span of
            // recorded data (the earliest covered instant up to 'to') so a fresh system still renders.
            var stores = Registry.KnownSubjects.Keys.OfType<IHistoryStore>().ToArray();
            var earliest = stores.Length == 0 ? (DateTimeOffset?)null : stores.Min(store => store.CurrentCoverage.From);
            TimeSpan? availableCoverage = earliest is { } coverageStart && coverageStart < to ? to - coverageStart : null;

            var bucket = PropertyHistoryChartModel.ResolveBucket(
                PropertyHistoryChartModel.Periods[_periodIndex], range, availableCoverage);

            _rangeHint = range <= TimeSpan.FromHours(24)
                ? $"{TimeZone.ToZoned(from):HH:mm} to {TimeZone.ToZoned(to):HH:mm}"
                : $"{TimeZone.ToZoned(from):MMM d, HH:mm} to {TimeZone.ToZoned(to):MMM d, HH:mm}";
            _periodHint = PropertyHistoryChartModel.DescribePeriod(PropertyHistoryChartModel.Periods[_periodIndex], bucket);
            _aggregationHint = PropertyHistoryChartModel.DescribeAggregation(_aggregation);

            _chartOptions.TimeLabelFormat = range <= TimeSpan.FromHours(24) ? "HH:mm" : "MM-dd";
            // For a raw (null bucket) query there is no aggregation interval, so space labels by the range alone.
            var rangeSpacingTicks = range.Ticks / 8;
            _chartOptions.TimeLabelSpacing = TimeSpan.FromTicks(
                bucket is null ? rangeSpacingTicks : Math.Max(rangeSpacingTicks, bucket.Value.Ticks));

            var series = await Registry.QueryHistoryAsync(
                new HistoryQuery(PropertyPath, from, to, bucket, _aggregation, MaxPoints: 1000),
                cancellationToken);

            // Superseded by a newer load while this query ran; leave the newer result in place.
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            BuildView(series);
        }
        catch (HistoryAggregationNotSupportedException exception)
        {
            _error = exception.Message;
            _chartSeries = null;
            _tableRows = null;
        }
        catch (OperationCanceledException)
        {
            return; // superseded by a newer load; leave its result in place
        }
        catch (Exception exception)
        {
            _error = "Could not load history: " + exception.Message;
            _chartSeries = null;
            _tableRows = null;
        }
        finally
        {
            // Only the current (non-superseded) load updates the loading state and re-renders.
            if (!cancellationToken.IsCancellationRequested)
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private void BuildView(HistorySeries series)
    {
        if (series.Points.Any(point => point.Number is not null))
        {
            var runs = PropertyHistoryChartModel.SplitIntoGapRuns(series.Points);
            _chartSeries = runs
                .Select(run => new ChartSeries<double>
                {
                    Name = DisplayName,
                    Visible = true,
                    Data = new ChartData<double>(
                        run.Select(point => (TimeZone.ToZoned(point.Timestamp), point.Number!.Value)).ToList())
                })
                .ToList();
            _tableRows = null;
        }
        else
        {
            _chartSeries = null;
            _tableRows = series.Points
                .Where(point => point.Json is not null)
                .Select(point => (point.Timestamp, point.Json!.Value.ToString()))
                .ToList();
        }
    }

    private static string Label(string aggregation) => aggregation switch
    {
        HistoryAggregations.TimeWeightedAverage => "Average",
        HistoryAggregations.SampleAverage => "Sample Average",
        _ => aggregation
    };

    private void Close() => MudDialog?.Close(DialogResult.Ok(true));

    private void OnTimeZoneChanged() => InvokeAsync(LoadAsync);

    public void Dispose()
    {
        TimeZone.Changed -= OnTimeZoneChanged;
        _loadCts?.Dispose();
    }

    public static Task<IDialogReference> ShowAsync(
        IDialogService dialogService,
        ISubjectRegistry registry,
        string propertyPath,
        string displayName,
        Type propertyType,
        bool isCumulative,
        string? unit = null)
    {
        var parameters = new DialogParameters<PropertyHistoryDialog>
        {
            { dialog => dialog.Registry, registry },
            { dialog => dialog.PropertyPath, propertyPath },
            { dialog => dialog.DisplayName, displayName },
            { dialog => dialog.PropertyType, propertyType },
            { dialog => dialog.IsCumulative, isCumulative }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var title = string.IsNullOrEmpty(unit) ? $"History: {displayName}" : $"History: {displayName} ({unit})";
        return dialogService.ShowAsync<PropertyHistoryDialog>(title, parameters, options);
    }
}
