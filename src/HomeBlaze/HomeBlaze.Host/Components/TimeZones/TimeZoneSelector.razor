@using HomeBlaze.Host.TimeZones
@using HomeBlaze.Services
@using MudBlazor
@implements IDisposable

@inject ITimeZoneDisplay TimeZone
@inject TimeZoneInterop Interop

<MudMenu @ref="_menu" Icon="@Icons.Material.Filled.Schedule" Color="Color.Inherit"
         title="@CurrentLabel" AriaLabel="Select timezone" MaxHeight="500">
    <div style="min-width: 320px;">
        <div style="position: sticky; top: 0; z-index: 1; background-color: var(--mud-palette-surface);">
            <MudTextField @bind-Value="_search" Placeholder="Search timezone" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="px-3 py-2" />
        </div>
        <MudList T="string" Dense="true">
            <MudListItem T="string" OnClick="@SelectAutomaticAsync">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <span><b>Automatic</b> (this browser)</span>
                    @if (TimeZone.Preference.IsAutomatic)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
                    }
                </div>
            </MudListItem>
            @foreach (var option in FilteredZones())
            {
                <MudListItem T="string" OnClick="@(() => SelectZoneAsync(option.Id))">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <span>@option.DisplayName</span>
                        @if (IsZoneSelected(option.Id))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
                        }
                    </div>
                </MudListItem>
            }
        </MudList>
    </div>
</MudMenu>

@code {
    private static readonly IReadOnlyList<TimeZoneOption> Zones = TimeZoneCatalog.GetZones();
    private MudMenu? _menu;
    private string _search = string.Empty;

    private string CurrentLabel => TimeZone.IsResolved
        ? (TimeZone.Preference.IsAutomatic ? $"Automatic ({TimeZone.Zone!.Id})" : TimeZone.Zone!.Id)
        : "Timezone";

    protected override void OnInitialized() => TimeZone.Changed += OnTimeZoneChanged;

    private void OnTimeZoneChanged() => InvokeAsync(StateHasChanged);

    private bool IsZoneSelected(string id) =>
        !TimeZone.Preference.IsAutomatic && TimeZone.IsResolved && TimeZone.Zone!.Id == id;

    private IEnumerable<TimeZoneOption> AllZones()
    {
        // The catalog is built from the OS's canonical zones, so a sibling zone the browser reports
        // (for example Europe/Zurich, which collapses into Europe/Berlin on Windows) may be missing.
        // Make the currently resolved zone selectable by adding it when the catalog lacks it.
        if (TimeZone.Zone is { } zone
            && !Zones.Any(option => string.Equals(option.Id, zone.Id, StringComparison.OrdinalIgnoreCase))
            && TimeZoneCatalog.CreateOption(zone) is { } current)
        {
            return Zones.Prepend(current);
        }

        return Zones;
    }

    private IEnumerable<TimeZoneOption> FilteredZones() =>
        string.IsNullOrWhiteSpace(_search)
            ? AllZones()
            : AllZones().Where(zone => zone.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private async Task SelectAutomaticAsync()
    {
        var browserZone = await Interop.GetBrowserTimeZoneAsync();
        TimeZone.SetResolved(TimeZonePreference.Automatic, TimeZoneResolver.Resolve(browserZone));
        await Interop.SetPreferenceCookieAsync(TimeZonePreference.Automatic.ToCookieValue());
        await CloseMenuAsync();
    }

    private async Task SelectZoneAsync(string id)
    {
        var preference = TimeZonePreference.Specific(id);
        TimeZone.SetResolved(preference, TimeZoneResolver.Resolve(id));
        await Interop.SetPreferenceCookieAsync(preference.ToCookieValue());
        await CloseMenuAsync();
    }

    private async Task CloseMenuAsync()
    {
        _search = string.Empty;
        if (_menu is not null)
        {
            await _menu.CloseMenuAsync();
        }
    }

    public void Dispose() => TimeZone.Changed -= OnTimeZoneChanged;
}
