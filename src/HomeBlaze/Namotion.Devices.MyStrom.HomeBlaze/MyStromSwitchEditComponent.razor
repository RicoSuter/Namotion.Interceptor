@using Namotion.Interceptor

@attribute [SubjectComponent(SubjectComponentType.Edit, typeof(MyStromSwitch))]
@implements ISubjectEditComponent

<MudForm>
    <MudTextField @bind-Value="_name"
                  Label="Name"
                  Immediate="true"
                  OnKeyUp="OnFieldChanged" />

    <MudTextField @bind-Value="_ipAddress"
                  Label="IP Address"
                  Required="true"
                  RequiredError="IP Address is required"
                  Immediate="true"
                  OnKeyUp="OnFieldChanged"
                  Class="mt-4" />

    <MudSwitch T="bool"
               Value="_allowTurnOff"
               ValueChanged="OnAllowTurnOffChanged"
               Label="Allow Turn Off"
               Color="Color.Primary"
               Class="mt-4" />

    <MudNumericField @bind-Value="_pollingIntervalSeconds"
                     Label="Polling Interval (seconds)"
                     Min="1"
                     Max="300"
                     Class="mt-4" />

    <MudNumericField @bind-Value="_retryIntervalSeconds"
                     Label="Retry Interval (seconds)"
                     Min="5"
                     Max="600"
                     Class="mt-4" />

    @if (!IsCreating)
    {
        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Current State</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudText>Connection:</MudText>
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(SwitchSubject?.IsConnected == true ? Color.Success : Color.Error)"
                     Variant="Variant.Filled">
                @(SwitchSubject?.IsConnected == true ? "Connected" : "Disconnected")
            </MudChip>
        </MudStack>
        @if (SwitchSubject?.FirmwareVersion != null)
        {
            <MudText Class="mt-1">Firmware: @SwitchSubject.FirmwareVersion</MudText>
        }
        @if (SwitchSubject?.MacAddress != null)
        {
            <MudText>MAC: @SwitchSubject.MacAddress</MudText>
        }
    }
</MudForm>

@code {
    [Parameter]
    public IInterceptorSubject? Subject { get; set; }

    [Parameter]
    public bool IsCreating { get; set; }

    private MyStromSwitch? SwitchSubject => Subject as MyStromSwitch;

    private string _name = string.Empty;
    private string? _ipAddress;
    private bool _allowTurnOff = true;
    private int _pollingIntervalSeconds = 15;
    private int _retryIntervalSeconds = 30;

    private string _originalName = string.Empty;
    private string? _originalIpAddress;
    private bool _originalAllowTurnOff = true;
    private int _originalPollingIntervalSeconds = 15;
    private int _originalRetryIntervalSeconds = 30;

    public bool IsValid => !string.IsNullOrWhiteSpace(_ipAddress);
    public bool IsDirty => _name != _originalName ||
                           _ipAddress != _originalIpAddress ||
                           _allowTurnOff != _originalAllowTurnOff ||
                           _pollingIntervalSeconds != _originalPollingIntervalSeconds ||
                           _retryIntervalSeconds != _originalRetryIntervalSeconds;

    public event Action<bool>? IsValidChanged;
    public event Action<bool>? IsDirtyChanged;

    protected override void OnInitialized()
    {
        if (SwitchSubject != null)
        {
            _name = SwitchSubject.Name;
            _ipAddress = SwitchSubject.HostAddress;
            _allowTurnOff = SwitchSubject.AllowTurnOff;
            _pollingIntervalSeconds = (int)SwitchSubject.PollingInterval.TotalSeconds;
            _retryIntervalSeconds = (int)SwitchSubject.RetryInterval.TotalSeconds;

            _originalName = _name;
            _originalIpAddress = _ipAddress;
            _originalAllowTurnOff = _allowTurnOff;
            _originalPollingIntervalSeconds = _pollingIntervalSeconds;
            _originalRetryIntervalSeconds = _retryIntervalSeconds;
        }
    }

    private void OnFieldChanged()
    {
        IsValidChanged?.Invoke(IsValid);
        IsDirtyChanged?.Invoke(IsDirty);
    }

    private void OnAllowTurnOffChanged(bool value)
    {
        _allowTurnOff = value;
        OnFieldChanged();
    }

    public Task SaveAsync(CancellationToken cancellationToken)
    {
        if (SwitchSubject != null && IsValid)
        {
            SwitchSubject.Name = _name;
            SwitchSubject.HostAddress = _ipAddress;
            SwitchSubject.AllowTurnOff = _allowTurnOff;
            SwitchSubject.PollingInterval = TimeSpan.FromSeconds(_pollingIntervalSeconds);
            SwitchSubject.RetryInterval = TimeSpan.FromSeconds(_retryIntervalSeconds);

            _originalName = _name;
            _originalIpAddress = _ipAddress;
            _originalAllowTurnOff = _allowTurnOff;
            _originalPollingIntervalSeconds = _pollingIntervalSeconds;
            _originalRetryIntervalSeconds = _retryIntervalSeconds;

            IsDirtyChanged?.Invoke(false);
        }

        return Task.CompletedTask;
    }
}
