<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
        <Watch Remove="Data/**/*" />
        <ProjectReference Include="..\Namotion.Devices.Gpio.HomeBlaze\Namotion.Devices.Gpio.HomeBlaze.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Gpio\Namotion.Devices.Gpio.csproj" />
        <ProjectReference Include="..\Namotion.Devices.MyStrom\Namotion.Devices.MyStrom.csproj" />
        <ProjectReference Include="..\Namotion.Devices.MyStrom.HomeBlaze\Namotion.Devices.MyStrom.HomeBlaze.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Shelly\Namotion.Devices.Shelly.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Shelly.HomeBlaze\Namotion.Devices.Shelly.HomeBlaze.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Wallbox\Namotion.Devices.Wallbox.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Wallbox.HomeBlaze\Namotion.Devices.Wallbox.HomeBlaze.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Ecowitt\Namotion.Devices.Ecowitt.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Ecowitt.HomeBlaze\Namotion.Devices.Ecowitt.HomeBlaze.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Philips.Hue\Namotion.Devices.Philips.Hue.csproj" />
        <ProjectReference Include="..\Namotion.Devices.Philips.Hue.HomeBlaze\Namotion.Devices.Philips.Hue.HomeBlaze.csproj" />
        <ProjectReference Include="..\HomeBlaze.AI\HomeBlaze.AI.csproj" />
        <ProjectReference Include="..\HomeBlaze.Host\HomeBlaze.Host.csproj" />
        <ProjectReference Include="..\HomeBlaze.Samples\HomeBlaze.Samples.csproj" />
        <ProjectReference Include="..\HomeBlaze.OpcUa\HomeBlaze.OpcUa.csproj" />
        <ProjectReference Include="..\HomeBlaze.OpcUa.Blazor\HomeBlaze.OpcUa.Blazor.csproj" />
        <ProjectReference Include="..\HomeBlaze.Plugins\HomeBlaze.Plugins.csproj" />
        <ProjectReference Include="..\MyCompany.SamplePlugin1.HomeBlaze\MyCompany.SamplePlugin1.HomeBlaze.csproj">
            <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
            <Private>false</Private>
        </ProjectReference>
        <ProjectReference Include="..\MyCompany.SamplePlugin2.HomeBlaze\MyCompany.SamplePlugin2.HomeBlaze.csproj">
            <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
            <Private>false</Private>
        </ProjectReference>
        <ProjectReference Include="..\..\Namotion.Interceptor.Generator\Namotion.Interceptor.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <PackageReference Include="BlazorMonaco" Version="3.4.0" />
        <PackageReference Include="CodeBeam.MudBlazor.Extensions" Version="9.0.3" />
        <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.2.0" />
    </ItemGroup>

    <ItemGroup>
        <Content Update="Data\**\*" CopyToOutputDirectory="PreserveNewest" />
        <Content Update="root.json" CopyToOutputDirectory="PreserveNewest" />
        <Content Remove="Data\Plans.json" />
        <!-- Plugins\*.nupkg are generated by sample plugin builds (GeneratePackageOnBuild).
             A Content Include glob would be evaluated before those targets run on clean builds.
             Copied via CopyPluginNupkgs target below instead. -->
    </ItemGroup>

    <Target Name="CopyPluginNupkgs" AfterTargets="Build">
        <ItemGroup>
            <_PluginNupkgs Include="Plugins\*.nupkg" />
        </ItemGroup>
        <Copy SourceFiles="@(_PluginNupkgs)" DestinationFolder="$(OutputPath)Plugins" SkipUnchangedFiles="true" />
    </Target>

</Project>
