<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>true</IsPackable>
    <Version>1.0.0</Version>
    <PackageOutputPath>../HomeBlaze/Plugins</PackageOutputPath>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MyCompany.SamplePlugin2\MyCompany.SamplePlugin2.csproj" />
    <ProjectReference Include="..\HomeBlaze.Components.Abstractions\HomeBlaze.Components.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MudBlazor" Version="9.2.*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="plugin.json" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
